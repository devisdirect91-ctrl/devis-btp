# ============================================================
# SUPABASE - Base de données PostgreSQL
# ============================================================

# URL de connexion via le connection pooler (Supabase > Settings > Database > Connection string > Transaction)
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[DB-PASSWORD]@aws-0-eu-west-3.pooler.supabase.com:6543/postgres?pgbouncer=true"

# URL directe sans pooler (Supabase > Settings > Database > Connection string > Session)
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[DB-PASSWORD]@aws-0-eu-west-3.pooler.supabase.com:5432/postgres"

# ============================================================
# NEXTAUTH
# ============================================================

# Générer avec : openssl rand -base64 32
NEXTAUTH_SECRET="change-me-generate-with-openssl-rand-base64-32"

# URL de votre application (sur Vercel : https://votre-projet.vercel.app)
NEXTAUTH_URL="https://votre-projet.vercel.app"

# ============================================================
# SUPABASE STORAGE (pour logos et PDFs)
# ============================================================

# Supabase > Settings > API > Project URL
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"

# Supabase > Settings > API > anon / public key
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."

# Supabase > Settings > API > service_role key (JAMAIS exposé côté client)
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# ============================================================
# RESEND (envoi d'emails)
# ============================================================

# Créer un compte sur resend.com > API Keys > Create API Key
# Sans cette clé, les emails sont désactivés (pas de crash)
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
